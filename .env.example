# ── JIRA / Atlassian ─────────────────────────────────────────────────────────

# Your Atlassian/JIRA Cloud domain
# Example: https://your-company.atlassian.net
JIRA_BASE_URL=https://your-company.atlassian.net

# The email address on your Atlassian account
JIRA_EMAIL=your-email@example.com

# API token from https://id.atlassian.com/manage-profile/security/api-tokens
# Token name: "Metrics Tool"
JIRA_API_TOKEN=your_api_token_here

# Expiry date of your JIRA API token (YYYY-MM-DD).
# The hub will show a reminder banner the day before this date.
# Update this whenever you regenerate your token.
JIRA_TOKEN_EXPIRES=YYYY-MM-DD

# ── Server ────────────────────────────────────────────────────────────────────

# Port for the local server (default: 3000)
PORT=3000

# ── Paths ─────────────────────────────────────────────────────────────────────

# Parent directory where all sibling repos are cloned.
# Update this if you clone repos somewhere other than C:\Git-Repositories.
# Used by new-terminal.bat, new-terminal.ps1, and go-live-testing-rux skill.
REPOS_PARENT=C:\Git-Repositories

# ── UI ────────────────────────────────────────────────────────────────────────

# App name shown in the topbar and browser tab (default: "QA Command Center")
APP_NAME=QA Command Center

# Subtitle shown on the home view below the date (e.g. "My Company · My Team")
ORG_SUBTITLE=My Company · My Team

# ── Release Pipeline ──────────────────────────────────────────────────────────

# GitHub organization that owns the release repos
GITHUB_ORG=your-github-org

# Jira project key and Daily Releases epic key
JIRA_PROJECT=PROJ
JIRA_RELEASES_EPIC=PROJ-0000

# Repo names within GITHUB_ORG used by the release pipeline
RELEASE_DEPLOY_REPO=your-deployment-repo
RELEASE_APP_REPO=your-app-repo

# MT (Main Track) regression tenant — QA environment
RELEASE_MT_SITE_DIR=your-mt-site-directory
RELEASE_MT_TENANT=your-mt-tenant-name
RELEASE_MT_TENANT_URL=https://your-mt-tenant.example.com/

# MT production/staging deployment site directory (used by releases-deploy skill)
RELEASE_MT_PROD_SITE_DIR=your-mt-prod-site-directory

# SUTS regression tenant — production smoke environment
RELEASE_SUTS_SITE_DIR=your-suts-site-directory
RELEASE_SUTS_TENANT=your-suts-tenant-name
RELEASE_SUTS_TENANT_URL=https://your-suts-tenant.example.com/

# ── Go-Live Testing ───────────────────────────────────────────────────────────

# Platform domain used for URL parsing in the go-live-testing-rux skill
# (the part after the tenant subdomain, e.g. blt.example.com)
BLT_DOMAIN=your-platform-domain.example.com
